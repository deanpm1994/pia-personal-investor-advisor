# Non-secret local development setting.
PIA_ENVIRONMENT=development

# Server-only local Supabase database URL. This default uses Supabase CLI's
# documented local database credentials; do not copy a hosted URL into source
# control or any apps/web environment file.
PIA_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:54322/postgres

# Server-only Supabase JWT verification settings. Do not put these values in
# apps/web; the browser uses only NEXT_PUBLIC_SUPABASE_URL and anon key.
PIA_SUPABASE_URL=http://localhost:54321
PIA_SUPABASE_JWT_AUDIENCE=authenticated
# Browser origin allowed to call the API in local development.
PIA_WEB_ORIGIN=http://localhost:3000
